import "oaidl.idl";
import "ocidl.idl";

[
    uuid(7f5d9a20-5b7b-4c3b-9d7f-2f5a60b8f1a1),
        version(1.0),
        implicit_handle(handle_t WitcherControl_IfHandle)
]
interface WitcherControl
{
    void RpcStopService(void);

    long RpcLogin(
        [in, string] const wchar_t* username,
        [in, string] const wchar_t* password
    );

    long RpcLogout(void);

    long RpcGetCurrentUser(
        [out] long* isAuthenticated,
        [out, size_is(usernameCapacity)] wchar_t* usernameBuffer,
        [in] unsigned long usernameCapacity
    );

    long RpcCheckLicense(
        [in, string] const wchar_t* licenseCode,
        [in, string] const wchar_t* macAddress,
        [in, string] const wchar_t* productId
    );

    long RpcActivateLicense(
        [in, string] const wchar_t* licenseCode,
        [in, string] const wchar_t* macAddress,
        [in, string] const wchar_t* productId
    );

    long RpcGetLicenseInfo(
        [out] long* hasLicense,
        [out, size_is(expirationDateCapacity)] wchar_t* expirationDateBuffer,
        [in] unsigned long expirationDateCapacity
    );

    long RpcRefreshLicenseStatus(void);

    long RpcGetAntivirusStatus(
        [out] long* isEnabled
    );

    long RpcGetAvDatabaseInfo(
        [out] long* isLoaded,
        [out, size_is(releaseDateCapacity)] wchar_t* releaseDateBuffer,
        [in] unsigned long releaseDateCapacity,
        [out] unsigned long long* recordCount
    );

    long RpcScanFile(
        [in, string] const wchar_t* filePath,
        [out] long* isMalicious,
        [out, size_is(threatNameCapacity)] wchar_t* threatNameBuffer,
        [in] unsigned long threatNameCapacity,
        [out] unsigned long long* scannedFiles,
        [out] unsigned long long* maliciousFiles
    );

    long RpcScanDirectory(
        [in, string] const wchar_t* directoryPath,
        [out] long* isMalicious,
        [out, size_is(threatNameCapacity)] wchar_t* threatNameBuffer,
        [in] unsigned long threatNameCapacity,
        [out] unsigned long long* scannedFiles,
        [out] unsigned long long* maliciousFiles
    );

    long RpcScanFixedDrives(
        [out] long* isMalicious,
        [out, size_is(threatNameCapacity)] wchar_t* threatNameBuffer,
        [in] unsigned long threatNameCapacity,
        [out] unsigned long long* scannedFiles,
        [out] unsigned long long* maliciousFiles
    );

    long RpcSetScheduledScan(
        [in] long isEnabled,
        [in] unsigned long intervalSeconds
    );

    long RpcGetScheduledScanStatus(
        [out] long* isEnabled,
        [out] unsigned long* intervalSeconds,
        [out] unsigned long long* lastScannedFiles,
        [out] unsigned long long* lastMaliciousFiles,
        [out] long* lastIsMalicious,
        [out, size_is(threatNameCapacity)] wchar_t* lastThreatNameBuffer,
        [in] unsigned long threatNameCapacity
    );

    long RpcSetMonitoredDirectory(
        [in] long isEnabled,
        [in, string] const wchar_t* directoryPath
    );

    long RpcGetMonitoredDirectoryStatus(
        [out] long* isEnabled,
        [out, size_is(directoryPathCapacity)] wchar_t* directoryPathBuffer,
        [in] unsigned long directoryPathCapacity,
        [out] unsigned long long* lastScannedFiles,
        [out] unsigned long long* lastMaliciousFiles,
        [out] long* lastIsMalicious,
        [out, size_is(threatNameCapacity)] wchar_t* lastThreatNameBuffer,
        [in] unsigned long threatNameCapacity
    );
}